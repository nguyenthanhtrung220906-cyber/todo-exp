{
  "name": "todo-exp",
  "productName": "Todo EXP",
  "version": "1.0.0",
  "description": "A gamified productivity app with EXP and level system",
  "main": "main.js",
  "author": {
    "name": "Todo EXP",
    "email": "app@todoexp.com"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --win --x64",
    "dist:dir": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.todoexp.desktop",
    "productName": "Todo EXP",
    "copyright": "Copyright © 2025 Todo EXP",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "data/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Todo EXP",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "menuCategory": "Productivity",
      "artifactName": "TodoEXP-Setup-${version}.exe",
      "license": "assets/license.txt",
      "installerLanguages": [
        "en-US"
      ],
      "displayLanguageSelector": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "nguyenthanhtrung220906-cyber",
        "repo": "todo-exp"
      }
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  }
}